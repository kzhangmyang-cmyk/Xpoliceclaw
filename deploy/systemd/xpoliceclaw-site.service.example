[Unit]
Description=Police Claw public download site
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/xpoliceclaw/app
Environment=PYTHONUNBUFFERED=1
Environment=XPOLICECLAW_HOST=127.0.0.1
Environment=XPOLICECLAW_PORT=8000
Environment=XPOLICECLAW_RUNTIME_ROOT=/var/lib/xpoliceclaw/runtime
Environment=XPOLICECLAW_RELEASE_ROOT=/var/lib/xpoliceclaw/releases
ExecStart=/opt/xpoliceclaw/app/.venv/bin/gunicorn -w 2 -b 127.0.0.1:8000 web_app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
